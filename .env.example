# ─── Anthropic ────────────────────────────────────────────────────────────────
# Required. Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ─── Google APIs ──────────────────────────────────────────────────────────────
# Required for URL safety checks. Enable "Safe Browsing API" in Google Cloud Console.
GOOGLE_SAFE_BROWSING_KEY=AIza...

# Required for image/screenshot OCR. Enable "Cloud Vision API" in Google Cloud Console.
GOOGLE_VISION_KEY=AIza...

# ─── VirusTotal ───────────────────────────────────────────────────────────────
# Optional but recommended. Free tier available at https://www.virustotal.com/
VIRUSTOTAL_API_KEY=

# ─── PhishTank ────────────────────────────────────────────────────────────────
# Optional. Without key it uses anonymous rate limit (~20 req/min).
# Register at https://www.phishtank.com/api_register.php
PHISHTANK_API_KEY=

# ─── WhatsApp Cloud API ───────────────────────────────────────────────────────
# Required only if using the WhatsApp bot integration.
# Get these from Meta for Developers → WhatsApp → Configuration
WHATSAPP_TOKEN=EAAx...
WHATSAPP_PHONE_NUMBER_ID=12345678
# Choose any secret string — must match what you configure in Meta webhook settings
WHATSAPP_VERIFY_TOKEN=un_token_secreto_que_eliges_tu

# ─── Backend server ───────────────────────────────────────────────────────────
# Port the Express server listens on (Railway sets this automatically)
PORT=3001
# Allowed CORS origin — set to your Vercel frontend URL in production
FRONTEND_URL=http://localhost:3000

# ─── Frontend (Next.js) ───────────────────────────────────────────────────────
# Must be prefixed with NEXT_PUBLIC_ to be accessible in the browser.
# Set to your Railway backend URL in production (e.g. https://your-app.railway.app)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
